# THERESE editor defaults — keeps UTF-8 consistent across the team.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{py,html,js,css,md,json,yml,yaml}]
indent_style = space
indent_size = 4

[*.{js,css,json,yml,yaml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false