# THERESE — environment variables (copy to .env and adjust)
# Setup:  python create_env_template.py   (creates .env only if missing)
#         or:  copy .env.example .env      (Windows)

# --- Django core ---
DEBUG=True
SECRET_KEY=change-me-generate-your-own

# Comma-separated hostnames/IPs (no spaces). Wildcards like 172.26.70.* work in base.py.
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Database ---
# Leave DB_HOST empty for SQLite (local development).
# Set DB_HOST for MariaDB/MySQL (production).
DB_HOST=
DB_NAME=therese
DB_USER=therese
DB_PASSWORD=
DB_PORT=3306

# --- HTTPS / Gunicorn (start_therese_prod.sh) ---
# Institute certificates on the server, or leave empty for self-signed certs/ in certs/
CERT_FILE=
KEY_FILE=