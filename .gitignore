# Django
db.sqlite3
*.pyc
*.pyo
__pycache__/

# Logs - niemals committen!
logs/
logs/**
EmployeeForm_*.txt
employee_form_init_*.txt
import_*_20*.txt
populate_*_20*.txt
*.log

# Virtuelle Umgebung
venv/
.venv/
ENV/

# Media & Static (generiert)
media/

# staticfiles/ is generated by collectstatic.
# We are including it in the repo so that all CSS, admin static and the logo
# are available after a simple git pull on the server (without needing to run
# collectstatic on the target every time).
!staticfiles/

# Entwicklung
.DS_Store
.vscode/
.idea/
terminals/
*.swp
*.swo

# Umgebungsdateien & Secrets
.env
.env.*
*.env

# Lokale Settings Dateien (nicht committen)
local_settings.py
settings/local.py
**/local*.py
**/*secret*.py
**/*password*.py
**/*credentials*.py

# Speziell ausgeschlossen (auf Wunsch)
therese/settings.py

# Sensible Zertifikate und Keys (niemals committen!)
certs/
*.pem
*.key
*.crt
*.p12
*.pfx

# Datenbank Backups
db.sqlite3.bak*
*.bak.*

# Generierte Laufzeit-Dateien (nicht versionieren)
current_*.txt
*snapshot*.txt
*-*-therese.txt
2026-*.txt
DEMO_ANLEITUNG.txt
FETCH_HEAD



# ============================================================
# Logo / Asset files - MUST be versioned (not ignored)
# ============================================================
# These are source assets used in the application UI.
# Even if broader image or static rules are added later, protect the logos.
!logo*.webp
!logo*.pdn
!logo*.png
!logo*.jpg
!static/images/logo*.webp
!static/images/logo*.png
!static/images/logo*.jpg
